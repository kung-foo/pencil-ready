---
/*
 * Per-kind thumbnail for the homepage card grid. Each thumb is a tiny
 * A4-ratio SVG rendered by typst from `src/assets/thumbs/<kind>.typ` —
 * a single sample problem on a page-shaped rectangle with a 1pt
 * outline.
 *
 * SVGs are minified and per-file id-prefixed at `make thumbs` time
 * (see Makefile + svgo.config.mjs in this dir). The per-file prefix
 * is critical: typst names glyph defs by content hash, so multiple
 * inlined thumbs collide on shared glyph IDs without it. With that
 * baked in, we use Astro's native SVG component import — Astro
 * inlines the markup with proper attribute scoping.
 *
 * Iteration scope: arithmetic kinds only for now. Other kinds fall
 * through to no render until we add their typst sources.
 */
import type { WorksheetKind } from "@/lib/api";
import AddThumb from "@/assets/thumbs/add.svg";
import SubtractThumb from "@/assets/thumbs/subtract.svg";
import MultiplyThumb from "@/assets/thumbs/multiply.svg";
import SimpleDivideThumb from "@/assets/thumbs/simple-divide.svg";

interface Props {
    kind: WorksheetKind;
    class?: string;
}
const { kind, class: className } = Astro.props;

// Dynamic-tag rendering requires a capitalized binding; map to one.
const Thumbs: Partial<Record<WorksheetKind, typeof AddThumb>> = {
    add: AddThumb,
    subtract: SubtractThumb,
    multiply: MultiplyThumb,
    "simple-divide": SimpleDivideThumb,
};
const Thumb = Thumbs[kind];
---

{Thumb && <Thumb class:list={["worksheet-thumb-svg", className]} />}

<style>
    /* Typst SVGs ship with intrinsic pt-based width/height. Override
       so the parent box controls size; default preserveAspectRatio
       keeps the natural A4 aspect. drop-shadow gives the page a
       subtle paper-on-card lift. */
    .worksheet-thumb-svg {
        width: 100%;
        height: 100%;
        display: block;
        filter: drop-shadow(0 1px 2px rgb(0 0 0 / 0.12))
            drop-shadow(0 2px 4px rgb(0 0 0 / 0.06));
    }
</style>
