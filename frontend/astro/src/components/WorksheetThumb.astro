---
/*
 * Per-kind thumbnail for the homepage card grid. Each thumb is a tiny
 * A4-ratio SVG rendered by typst from `src/assets/thumbs/<kind>.typ` —
 * a single sample problem on a page-shaped rectangle with a 1pt
 * outline. Importing with `?raw` inlines the SVG markup into the HTML
 * so the parent box (CSS) controls visual size.
 *
 * Iteration scope: arithmetic kinds only for now (add/sub/multiply/
 * simple-divide). Other kinds fall through to no render until we add
 * their typst sources.
 */
import type { WorksheetKind } from "@/lib/api";
import addSvg from "@/assets/thumbs/add.svg?raw";
import subtractSvg from "@/assets/thumbs/subtract.svg?raw";
import multiplySvg from "@/assets/thumbs/multiply.svg?raw";
import simpleDivideSvg from "@/assets/thumbs/simple-divide.svg?raw";

interface Props {
    kind: WorksheetKind;
    class?: string;
}
const { kind, class: className } = Astro.props;

const thumbs: Partial<Record<WorksheetKind, string>> = {
    add: addSvg,
    subtract: subtractSvg,
    multiply: multiplySvg,
    "simple-divide": simpleDivideSvg,
};
const svg = thumbs[kind];
---

{
    svg && (
        <div class:list={["worksheet-thumb", className]} set:html={svg} />
    )
}

<style>
    /* Typst SVGs ship with intrinsic pt-based width/height attrs.
       Override so the parent box controls size; default
       preserveAspectRatio keeps the natural A4 aspect.
       drop-shadow gives the page a subtle paper-on-card lift. */
    .worksheet-thumb :global(svg) {
        width: 100%;
        height: 100%;
        display: block;
        filter: drop-shadow(0 1px 2px rgb(0 0 0 / 0.12))
            drop-shadow(0 2px 4px rgb(0 0 0 / 0.06));
    }
</style>
