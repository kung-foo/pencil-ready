---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import PencilRule from "../components/PencilRule.astro";
import InlineIcon from "../components/InlineIcon.astro";
import "../styles/global.css";
// `?raw` reads the SVG files at build time so the markup ships inlined
// in the HTML — no extra round trip. The public/ files remain the single
// source of truth (favicon link still references /rainbow-heart.svg).
import heartSvgRaw from "../../public/rainbow-heart.svg?raw";
import githubSvgRaw from "../../public/github.svg?raw";

interface Props {
    title: string;
    description?: string;
    canonical?: string;
}

const { title, description, canonical } = Astro.props;
const ogImage = "https://pencilready.com/og-image-1200x630.png";

// Build-time values for the Umami inline script below. `define:vars`
// turns these into top-of-script `const` declarations the JS body can
// reference, so the script is real JS (Prettier-formatted, syntax-
// highlighted) rather than a stringified blob.
const umami = {
    enabled: !import.meta.env.DEV,
    websiteId: "d47a9f9a-d800-408b-82f5-172a39ab9072",
    hostUrl: "/umami",
};
---

<!doctype html>
<html lang="en" data-theme="graph-paper">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        {description && <meta name="description" content={description} />}
        {canonical && <link rel="canonical" href={canonical} />}
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        {
            description && (
                <meta property="og:description" content={description} />
            )
        }
        {canonical && <meta property="og:url" content={canonical} />}
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        {
            description && (
                <meta name="twitter:description" content={description} />
            )
        }
        <meta name="twitter:image" content={ogImage} />
        <link rel="icon" type="image/svg+xml" href="/rainbow-heart.svg" />
        <link
            rel="sitemap"
            type="application/xml"
            title="Sitemap"
            href="/sitemap-index.xml"
        />
        <!-- Astro Fonts API: emits @font-face inline with computed
             metric overrides (size-adjust + ascent/descent/line-gap)
             calibrated against each fallback stack, so the swap-in
             from fallback to webfont doesn't shift layout. `preload`
             primes the body weight (Roboto Slab 400) and Crimson Text
             SemiBold used in headings — both above the fold on every
             page. The other Roboto Slab weights (500/600) load
             without preload since they appear only below the fold or
             in lazy-rendered islands. -->
        <Font
            cssVariable="--font-roboto-slab"
            preload={[{ weight: 400, style: "normal" }]}
        />
        <Font cssVariable="--font-crimson-text" preload />
        <!--
          iOS Chrome / Edge back-button workaround for Astro #11919.
          On those two browsers (CriOS / EdgiOS — both WebKit but with
          their own UA tokens; iOS Safari itself is unaffected),
          ClientRouter's JS-pushed history entries get silently
          discarded on back-press from an address-bar-loaded tab:
          popstate never fires, pageshow never fires, the tab just
          exits. Verified empirically on iOS 26 / Chrome 146; the
          fixes circulating in the issue thread (skip-replaceState +
          popstate-intercept, sentinel pushState) all assume popstate
          fires and don't help.

          Workaround: hijack internal link clicks in the capture phase
          before ClientRouter's delegated handler runs, and force a
          real `window.location.assign()` navigation. The browser then
          tracks the entry natively, so back works. Astro's
          prefetch (configured site-wide as `hover`) warms the
          destination so the MPA reload uses cached resources. The
          cost is a brief flash on that one transition, only on iOS
          Chrome / Edge — every other browser keeps the smooth SPA
          path.

          MUST run before <ClientRouter /> so the capture-phase
          listener wins the click delegation race.
        -->
        <script is:inline>
            (() => {
                if (!/CriOS|EdgiOS/.test(navigator.userAgent)) return;
                document.addEventListener(
                    "click",
                    (e) => {
                        if (
                            e.defaultPrevented ||
                            e.metaKey ||
                            e.ctrlKey ||
                            e.shiftKey ||
                            e.altKey ||
                            e.button !== 0
                        )
                            return;
                        const link =
                            e.target && e.target.closest
                                ? e.target.closest("a[href]")
                                : null;
                        if (!link) return;
                        if (link.target && link.target !== "_self") return;
                        if (link.hasAttribute("download")) return;
                        let url;
                        try {
                            url = new URL(link.href, location.href);
                        } catch {
                            return;
                        }
                        if (url.origin !== location.origin) return;
                        // Same-page hash link — let the browser handle.
                        if (
                            url.pathname === location.pathname &&
                            url.search === location.search &&
                            url.hash
                        )
                            return;
                        e.preventDefault();
                        e.stopImmediatePropagation();
                        window.location.assign(url.href);
                    },
                    true,
                );
            })();
        </script>
        <ClientRouter />
        <!-- Inject the Umami tracker after first paint. A `<script defer>`
             in <head> still pulls /umami/api/send into PageSpeed's LCP
             critical chain (~1.8s cold). Scheduling via window.load +
             requestIdleCallback moves the tracking ping past LCP without
             losing pageviews — Umami's `data-performance` PerformanceObserver
             still grabs buffered LCP/CLS that already fired. -->
        <script is:inline define:vars={umami}>
            (() => {
                if (!enabled) return;
                if (window.__umamiInjected) return;
                window.__umamiInjected = true;
                const inject = () => {
                    const s = document.createElement("script");
                    s.defer = true;
                    s.src = `${hostUrl}/script.js`;
                    s.dataset.websiteId = websiteId;
                    s.dataset.hostUrl = hostUrl;
                    s.dataset.doNotTrack = "true";
                    s.dataset.performance = "true";
                    document.head.appendChild(s);
                };
                const schedule = () =>
                    "requestIdleCallback" in window
                        ? requestIdleCallback(inject, { timeout: 2000 })
                        : setTimeout(inject, 250);
                if (document.readyState === "complete") schedule();
                else window.addEventListener("load", schedule, { once: true });
            })();
        </script>
    </head>
    <body class="min-h-screen flex flex-col">
        <header
            class="border-b px-3 py-1 flex items-center justify-between gap-4"
        >
            <div>
                <!-- inline-flex column sizes to the wordmark's natural
                     width; the PencilRule SVG inherits that width and
                     stretches because preserveAspectRatio is disabled
                     (see pencilready-logo-spec.md). Keep the tagline a
                     sibling — putting it inside this anchor would widen
                     the column and stretch the pencil rule. -->
                <a
                    href="/"
                    class="inline-flex flex-col items-stretch leading-none isolate"
                >
                    <h1 class="text-[2.5em] leading-none relative z-10">
                        Pencil Ready
                    </h1>
                    <PencilRule class="h-2 -mt-2" />
                </a>
                <p
                    class="header-tagline text-[0.8rem] text-muted-foreground tracking-wide whitespace-nowrap"
                >
                    print → solve → sharpen → repeat
                </p>
            </div>
            <nav class="text-sm">
                <a
                    href="/about/"
                    class="text-muted-foreground hover:text-foreground transition-colors"
                >
                    About
                </a>
            </nav>
        </header>
        <main class="flex-1">
            <slot />
        </main>
        <footer class="text-center text-xs text-muted-foreground">
            <PencilRule class="h-0.5" />
            <div class="px-6 py-3">
                <span class="font-semibold">Pencil Ready</span>
                <span class="mx-2">—</span>
                made with <InlineIcon svg={heartSvgRaw} /> in Oslo
                <span class="mx-2">—</span>
                <a
                    href="https://github.com/kung-foo/pencil-ready"
                    class="hover:text-foreground transition-colors"
                    rel="noopener"
                    aria-label="Source on GitHub"
                >
                    <InlineIcon svg={githubSvgRaw} /> source
                </a>
                {
                    /* Rewritten at response time by the Rust server (see
                    region_rewrite). `pnpm dev` bypasses the proxy, so
                    skip emitting the raw token in dev. */
                }
                <span class="ml-1 text-muted-foreground/60">
                    {import.meta.env.DEV ? "" : "SERVER_REGION_PLACEHOLDER"}
                </span>
            </div>
        </footer>
        <!-- 12px hysteresis (on >32, off <20) avoids flicker when a
             scroll lands right on the boundary. Re-runs on
             astro:page-load so it survives ClientRouter swaps. -->
        <script is:inline>
            (() => {
                const setup = () => {
                    const header = document.querySelector("body > header");
                    if (!header) return;
                    const onScroll = () => {
                        const y = window.scrollY;
                        if (y > 32) header.classList.add("is-condensed");
                        else if (y < 20)
                            header.classList.remove("is-condensed");
                    };
                    onScroll();
                    window.addEventListener("scroll", onScroll, {
                        passive: true,
                    });
                };
                document.addEventListener("astro:page-load", setup);
                if (document.readyState !== "loading") setup();
                else
                    document.addEventListener("DOMContentLoaded", setup, {
                        once: true,
                    });
            })();
        </script>
    </body>
</html>
