---
import { ClientRouter } from "astro:transitions";
import PencilRule from "../components/PencilRule.astro";
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
    canonical?: string;
}

const { title, description, canonical } = Astro.props;
const ogImage = "https://pencilready.com/og-image-1200x630.png";
---

<!doctype html>
<html lang="en" data-theme="graph-paper">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        {description && <meta name="description" content={description} />}
        {canonical && <link rel="canonical" href={canonical} />}
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        {
            description && (
                <meta property="og:description" content={description} />
            )
        }
        {canonical && <meta property="og:url" content={canonical} />}
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        {
            description && (
                <meta name="twitter:description" content={description} />
            )
        }
        <meta name="twitter:image" content={ogImage} />
        <link rel="icon" type="image/svg+xml" href="/rainbow-heart.svg" />
        <link
            rel="sitemap"
            type="application/xml"
            title="Sitemap"
            href="/sitemap-index.xml"
        />
        <!-- Critical font preloads. Crimson Text SemiBold is used for the
         "Pencil Ready" title in the header — preloading it keeps the
         wordmark from flashing in a fallback serif on first paint. -->
        <link
            rel="preload"
            as="font"
            type="font/woff2"
            href="/fonts/CrimsonText-SemiBold.woff2"
            crossorigin
        />
        <link
            rel="preload"
            as="font"
            type="font/woff2"
            href="/fonts/RobotoSlab-Regular.woff2"
            crossorigin
        />
        <link
            rel="preload"
            as="font"
            type="font/woff2"
            href="/fonts/RobotoSlab-SemiBold.woff2"
            crossorigin
        />
        <!-- Client-side routing with a View Transitions swap. Doesn't touch
         the generated per-route HTML — purely a progressive UX layer. -->
        <ClientRouter />
    </head>
    <!-- Layout mirrors the React App shell: fixed-ish header + footer,
       full-width flexible main. The per-page Astro file (e.g.
       worksheets/[kind].astro) owns its inner grid. -->
    <body class="min-h-screen flex flex-col">
        <header
            class="border-b px-3 flex items-center justify-between gap-4"
        >
            <div>
                <!-- inline-flex column sizes the wrapper to the wordmark's
                     natural width; the SVG inherits that width via
                     items-stretch and stretches horizontally (yellow barrel
                     absorbs the slack) because preserveAspectRatio is
                     disabled. See pencilready-logo-spec.md. -->
                <a
                    href="/"
                    class="inline-flex flex-col items-stretch leading-none isolate"
                >
                    <h1 class="text-[2.5em] leading-none relative z-10">
                        Pencil Ready
                    </h1>
                    <PencilRule class="h-2 -mt-2" />
                </a>
                <!-- Tagline lives outside the wordmark anchor so it doesn't
                     widen the inline-flex column (which would stretch the
                     pencil-rule SVG). header-tagline is the hook for the
                     scroll-driven fade-out (see styles/index.css). -->
                <p
                    class="header-tagline mt-2 text-xs text-muted-foreground tracking-wide whitespace-nowrap"
                >
                    print → solve → sharpen → repeat
                </p>
            </div>
            <nav class="text-sm">
                <a
                    href="/about/"
                    class="text-muted-foreground hover:text-foreground transition-colors"
                >
                    About
                </a>
            </nav>
        </header>
        <main class="flex-1">
            <slot />
        </main>
        <footer class="text-center text-xs text-muted-foreground">
            <PencilRule class="h-0.5" />
            <div class="px-6 py-3">
                <span class="font-semibold">Pencil Ready</span>
                <span class="mx-2">—</span>
                made with{" "}
                <img
                    src="/rainbow-heart.svg"
                    alt="rainbow heart"
                    class="inline size-4 align-middle -mt-0.5"
                />{" "}
                in Oslo
                <span class="mx-2">—</span>
                <a
                    href="https://github.com/kung-foo/pencil-ready"
                    class="hover:text-foreground transition-colors"
                    rel="noopener"
                    aria-label="Source on GitHub"
                >
                    {/* Inlined so fill="currentColor" inherits the
                        footer's text color. Mirrors /public/github.svg
                        for non-Astro consumers. `align-middle -mt-0.5`
                        matches the rainbow-heart nudge above so both
                        glyphs sit on the same visual baseline. */}
                    <svg
                        viewBox="0 0 98 96"
                        xmlns="http://www.w3.org/2000/svg"
                        aria-hidden="true"
                        class="inline size-4 align-middle -mt-0.5"
                    >
                        <path
                            fill="currentColor"
                            d="M41.4395 69.3848C28.8066 67.8535 19.9062 58.7617 19.9062 46.9902C19.9062 42.2051 21.6289 37.0371 24.5 33.5918C23.2559 30.4336 23.4473 23.7344 24.8828 20.959C28.7109 20.4805 33.8789 22.4902 36.9414 25.2656C40.5781 24.1172 44.4062 23.543 49.0957 23.543C53.7852 23.543 57.6133 24.1172 61.0586 25.1699C64.0254 22.4902 69.2891 20.4805 73.1172 20.959C74.457 23.543 74.6484 30.2422 73.4043 33.4961C76.4668 37.1328 78.0937 42.0137 78.0937 46.9902C78.0937 58.7617 69.1934 67.6621 56.3691 69.2891C59.623 71.3945 61.8242 75.9883 61.8242 81.252L61.8242 91.2051C61.8242 94.0762 64.2168 95.7031 67.0879 94.5547C84.4102 87.9512 98 70.6289 98 49.1914C98 22.1074 75.9883 0 48.9043 0C21.8203 0 0 22.1074 0 49.1914C0 70.4375 13.4941 88.0469 31.6777 94.6504C34.2617 95.6074 36.75 93.8848 36.75 91.3008L36.75 83.6445C35.4102 84.2188 33.6875 84.6016 32.1562 84.6016C25.8398 84.6016 22.1074 81.1563 19.4277 74.7441C18.375 72.1602 17.2266 70.6289 15.0254 70.3418C13.877 70.2461 13.4941 69.7676 13.4941 69.1934C13.4941 68.0449 15.4082 67.1836 17.3223 67.1836C20.0977 67.1836 22.4902 68.9063 24.9785 72.4473C26.8926 75.2227 28.9023 76.4668 31.2949 76.4668C33.6875 76.4668 35.2187 75.6055 37.4199 73.4043C39.0469 71.7773 40.291 70.3418 41.4395 69.3848Z"
                        ></path>
                    </svg>{" "}
                    source
                </a>
                {/* Rewritten at response time by the Rust server — see
                    region_rewrite middleware. `pnpm dev` skips the Rust
                    proxy, so guard on import.meta.env.DEV to keep the raw
                    token out of dev-mode pages. */}
                <span class="ml-1 text-muted-foreground/60">
                    {import.meta.env.DEV ? "" : "SERVER_REGION_PLACEHOLDER"}
                </span>
            </div>
        </footer>
        <!-- Toggle the header into its condensed state once the user has
             scrolled past the threshold. CSS handles the actual transition
             (see styles/index.css → .is-condensed). The 12px hysteresis
             between the on (>32) and off (<20) thresholds avoids flicker
             when a scroll lands right on the boundary. Re-runs on every
             astro:page-load so it survives ClientRouter view transitions. -->
        <script is:inline>
            (() => {
                const setup = () => {
                    const header = document.querySelector("body > header");
                    if (!header) return;
                    const onScroll = () => {
                        const y = window.scrollY;
                        if (y > 32) header.classList.add("is-condensed");
                        else if (y < 20) header.classList.remove("is-condensed");
                    };
                    onScroll();
                    window.addEventListener("scroll", onScroll, {
                        passive: true,
                    });
                };
                document.addEventListener("astro:page-load", setup);
                if (document.readyState !== "loading") setup();
                else
                    document.addEventListener(
                        "DOMContentLoaded",
                        setup,
                        { once: true },
                    );
            })();
        </script>
    </body>
</html>
