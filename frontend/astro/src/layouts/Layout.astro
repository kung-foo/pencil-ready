---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
    canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="graph-paper">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        {description && <meta name="description" content={description} />}
        {canonical && <link rel="canonical" href={canonical} />}
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        {
            description && (
                <meta property="og:description" content={description} />
            )
        }
        <link rel="icon" type="image/svg+xml" href="/rainbow-heart.svg" />
        <link
            rel="sitemap"
            type="application/xml"
            title="Sitemap"
            href="/sitemap-index.xml"
        />
        <!-- Critical font preloads. Crimson Text SemiBold is used for the
         "Pencil Ready" title in the header — preloading it keeps the
         wordmark from flashing in a fallback serif on first paint. -->
        <link
            rel="preload"
            as="font"
            type="font/woff2"
            href="/fonts/CrimsonText-SemiBold.woff2"
            crossorigin
        />
        <link
            rel="preload"
            as="font"
            type="font/woff2"
            href="/fonts/RobotoSlab-Regular.woff2"
            crossorigin
        />
        <link
            rel="preload"
            as="font"
            type="font/woff2"
            href="/fonts/RobotoSlab-SemiBold.woff2"
            crossorigin
        />
        <!-- Client-side routing with a View Transitions swap. Doesn't touch
         the generated per-route HTML — purely a progressive UX layer. -->
        <ClientRouter />
    </head>
    <!-- Layout mirrors the React App shell: fixed-ish header + footer,
       full-width flexible main. The per-page Astro file (e.g.
       worksheets/[kind].astro) owns its inner grid. -->
    <body class="min-h-screen flex flex-col">
        <header
            class="border-b px-3 py-3 flex items-center justify-between gap-4"
        >
            <!-- inline-flex column sizes the wrapper to the wordmark's
                 natural width; the SVG inherits that width via
                 items-stretch and stretches horizontally (yellow barrel
                 absorbs the slack) because preserveAspectRatio is
                 disabled. See pencilready-logo-spec.md. -->
            <a
                href="/"
                class="inline-flex flex-col items-stretch leading-none isolate"
            >
                <h1 class="text-[2.5em] leading-none relative z-10">
                    Pencil Ready
                </h1>
                <svg
                    preserveAspectRatio="none"
                    viewBox="0 0 288 12"
                    shape-rendering="crispEdges"
                    class="w-full h-2 -mt-2"
                    aria-hidden="true"
                >
                    <rect x="0" y="0" width="12" height="12" fill="#E88E8A"
                    ></rect>
                    <rect x="12" y="0" width="6" height="12" fill="#3E8948"
                    ></rect>
                    <rect x="18" y="0" width="6" height="12" fill="#FDB600"
                    ></rect>
                    <rect x="24" y="0" width="6" height="12" fill="#3E8948"
                    ></rect>
                    <rect x="30" y="0" width="252" height="12" fill="#FDB600"
                    ></rect>
                    <rect x="282" y="0" width="6" height="12" fill="#1A1A1A"
                    ></rect>
                </svg>
            </a>
            <nav class="text-sm">
                <a
                    href="/about/"
                    class="text-muted-foreground hover:text-foreground transition-colors"
                >
                    About
                </a>
            </nav>
        </header>
        <main class="flex-1">
            <slot />
        </main>
        <footer
            class="border-t px-6 py-3 text-center text-xs text-muted-foreground"
        >
            <span class="font-semibold">Pencil Ready</span>
            <span class="mx-2">—</span>
            made with{" "}
            <img
                src="/rainbow-heart.svg"
                alt="rainbow heart"
                class="inline size-4 align-middle -mt-0.5"
            />{" "}
            in Oslo
        </footer>
    </body>
</html>
