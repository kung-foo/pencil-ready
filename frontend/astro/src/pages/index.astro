---
import Layout from "../layouts/Layout.astro";
import WorksheetThumb from "../components/WorksheetThumb.astro";
import { WORKSHEET_INFO, WORKSHEET_SECTIONS } from "../lib/worksheet-info";
---

<Layout
    title="Pencil Ready — printable math worksheets"
    description="Free, printable math worksheets for 1st–6th grade — print → solve → sharpen → repeat. Addition, subtraction, multiplication, long division, fractions, and two-step equations — configure the difficulty and download as PDF."
    canonical="https://pencilready.com/"
>
    <div class="p-4 md:p-8 max-w-6xl mx-auto">
        <h1 class="text-3xl font-semibold mb-8">Printable math worksheets</h1>

        <!--
          Sectioned layout: one heading + card grid per topic cluster.
          Section order is curriculum-progression (arithmetic → drills →
          long-form → fractions → pre-algebra); within each, order
          matches classroom sequencing. The card grid reuses the same
          shadcn card tokens as the per-type pages for visual cohesion.
          Sections stack vertically on mobile — no extra breakpoints
          needed for the section structure itself.
        -->
        <div class="space-y-10">
            {
                WORKSHEET_SECTIONS.map((section) => (
                    <section>
                        <h2 class="text-xl font-semibold mb-4 pb-1 border-b border-pencil-no-2">
                            {section.title}
                        </h2>
                        <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                            {section.kinds.map((kind) => {
                                const info = WORKSHEET_INFO[kind];
                                return (
                                    <li>
                                        <a
                                            href={`/worksheets/${kind}/`}
                                            class="flex gap-3 h-full p-5 rounded-xl border bg-card text-card-foreground shadow hover:border-primary transition"
                                        >
                                            <div class="flex-1 min-w-0">
                                                <h3 class="font-semibold mb-1">
                                                    {info.title}
                                                </h3>
                                                <div class="text-sm text-muted-foreground">
                                                    {info.summary}
                                                </div>
                                            </div>
                                            <div class="flex-shrink-0 w-14 self-start text-foreground/70">
                                                <WorksheetThumb kind={kind} />
                                            </div>
                                        </a>
                                    </li>
                                );
                            })}
                        </ul>
                    </section>
                ))
            }
        </div>
    </div>
</Layout>
