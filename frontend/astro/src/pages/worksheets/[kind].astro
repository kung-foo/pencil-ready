---
import Layout from "../../layouts/Layout.astro";
import { WORKSHEET_KINDS, type WorksheetKind } from "../../lib/api";
import { WORKSHEET_INFO } from "../../lib/worksheet-info";
import { WorksheetIsland } from "../../components/WorksheetIsland";
import {
    Breadcrumb,
    BreadcrumbItem,
    BreadcrumbLink,
    BreadcrumbList,
    BreadcrumbPage,
    BreadcrumbSeparator,
} from "../../components/ui/breadcrumb";

export function getStaticPaths() {
    return WORKSHEET_KINDS.map((kind) => ({ params: { kind } }));
}

const { kind } = Astro.params as { kind: WorksheetKind };
const info = WORKSHEET_INFO[kind];
---

<Layout
    title={`${info.title} — Pencil Ready`}
    description={info.summary}
    canonical={`https://pencilready.com/worksheets/${kind}/`}
>
    <!--
    Page layout mirrors the React WorksheetPage 1:1: the island covers the
    first two grid tracks (config 320px + preview 1fr), and the help card
    takes a 320px right track. `minmax(0,1fr)` on the middle track keeps
    the preview A4 sizing from blowing out on very wide screens. The
    breadcrumb is the one intentional difference — Astro gives each kind
    its own URL so a breadcrumb makes sense here.
  -->
    <div class="px-4 pt-4">
        <Breadcrumb>
            <BreadcrumbList>
                <BreadcrumbItem>
                    <BreadcrumbLink href="/">All worksheets</BreadcrumbLink>
                </BreadcrumbItem>
                <BreadcrumbSeparator />
                <BreadcrumbItem>
                    <BreadcrumbPage>{info.title}</BreadcrumbPage>
                </BreadcrumbItem>
            </BreadcrumbList>
        </Breadcrumb>
    </div>

    <div
        class="flex flex-col gap-4 p-4 md:grid md:grid-cols-[minmax(0,1fr)_320px]"
    >
        <WorksheetIsland client:only="react" kind={kind}>
            <div
                slot="fallback"
                class="grid gap-4 md:grid-cols-[320px_1fr]"
                data-theme="graph-paper"
            >
                <div class="space-y-3">
                    <div class="rounded-xl border bg-card shadow h-[560px]">
                    </div>
                    <div class="rounded-md bg-muted h-9"></div>
                    <div class="rounded-md bg-muted h-9"></div>
                </div>
                <div
                    class="aspect-[210/297] md:aspect-auto md:min-h-[80vh] flex items-start justify-center"
                    style="container-type: size;"
                >
                    <div
                        class="bg-white rounded-sm ring-1 ring-black/5 shadow-[0_4px_16px_rgba(0,0,0,0.08),0_1px_3px_rgba(0,0,0,0.06)]"
                        style="width: min(100cqw, calc(100cqh * 210 / 297)); aspect-ratio: 210 / 297;"
                    >
                    </div>
                </div>
            </div>
        </WorksheetIsland>

        <aside>
            <div class="stippled rounded-xl border bg-card text-card-foreground shadow">
                <canvas class="stipple-canvas"></canvas>
                <div class="px-6 pt-4 pb-0">
                    <h2 class="text-lg pb-0 border-b border-pencil-no-2">
                        About this worksheet
                    </h2>
                </div>
                <div class="px-6 pb-6 pt-3 space-y-4">
                    <p class="text-sm text-muted-foreground italic">
                        {info.summary}
                    </p>

                    <div class="space-y-2">
                        <div
                            class="flex items-center gap-2 text-sm font-semibold"
                        >
                            <span class="text-muted-foreground">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="size-4"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M12 7v14"></path>
                                    <path
                                        d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"
                                    ></path>
                                </svg>
                            </span>
                            <span>Before you start</span>
                        </div>
                        <ul
                            class="text-sm space-y-1.5 pl-6 list-disc marker:text-muted-foreground"
                        >
                            {info.prerequisites.map((p) => <li>{p}</li>)}
                        </ul>
                    </div>

                    <div class="space-y-2">
                        <div
                            class="flex items-center gap-2 text-sm font-semibold"
                        >
                            <span class="text-muted-foreground">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="size-4"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path
                                        d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"
                                    ></path>
                                    <path d="M22 10v6"></path>
                                    <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"
                                    ></path>
                                </svg>
                            </span>
                            <span>With mastery, the student learns</span>
                        </div>
                        <ul
                            class="text-sm space-y-1.5 pl-6 list-disc marker:text-muted-foreground"
                        >
                            {info.learning.map((l) => <li>{l}</li>)}
                        </ul>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</Layout>
