---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Not found — Pencil Ready"
    description="The page you're looking for doesn't exist. Head back to the worksheets."
>
    <div class="p-4 md:p-8 max-w-xl mx-auto">
        <article
            class="rounded-xl border bg-card text-card-foreground shadow p-6 md:p-10 space-y-6 text-center"
        >
            <header class="space-y-2">
                <p class="text-5xl font-semibold text-pencil-no-2">404</p>
                <h1
                    class="text-2xl font-semibold pb-0 border-b-2 border-pencil-no-2 inline-block"
                >
                    Page not found
                </h1>
            </header>

            <svg
                viewBox="0 0 400 180"
                xmlns="http://www.w3.org/2000/svg"
                role="img"
                aria-labelledby="bp-title bp-desc"
                class="w-full max-w-sm mx-auto"
            >
                <title id="bp-title">Broken pencil</title>
                <desc id="bp-desc"
                    >A pixelated number two pencil snapped in half.</desc
                >

                <!-- Left piece: eraser, ferrule, half barrel, wood at break, graphite nub -->
                <g transform="rotate(-7 180 90)">
                    <rect x="20" y="50" width="32" height="80" fill="#E88E8A"
                    ></rect>
                    <rect x="52" y="50" width="16" height="80" fill="#3E8948"
                    ></rect>
                    <rect x="68" y="50" width="16" height="80" fill="#FDB600"
                    ></rect>
                    <rect x="84" y="50" width="16" height="80" fill="#3E8948"
                    ></rect>
                    <rect x="100" y="50" width="48" height="80" fill="#FDB600"
                    ></rect>
                    <rect x="148" y="66" width="16" height="48" fill="#D9A066"
                    ></rect>
                    <rect x="164" y="82" width="16" height="16" fill="#1A1A1A"
                    ></rect>
                </g>

                <!-- Right piece: graphite nub, wood at break, half barrel, tip -->
                <g transform="rotate(7 230 90)">
                    <rect x="230" y="82" width="16" height="16" fill="#1A1A1A"
                    ></rect>
                    <rect x="246" y="66" width="16" height="48" fill="#D9A066"
                    ></rect>
                    <rect x="262" y="50" width="96" height="80" fill="#FDB600"
                    ></rect>
                    <rect x="358" y="50" width="16" height="80" fill="#1A1A1A"
                    ></rect>
                </g>

                <!-- Graphite shards in the gap -->
                <rect
                    x="190"
                    y="56"
                    width="12"
                    height="5"
                    fill="#1A1A1A"
                    transform="rotate(25 196 58)"></rect>
                <rect
                    x="204"
                    y="122"
                    width="10"
                    height="5"
                    fill="#1A1A1A"
                    transform="rotate(-30 209 124)"></rect>
                <rect x="198" y="102" width="5" height="5" fill="#1A1A1A"
                ></rect>
            </svg>

            <p class="text-muted-foreground">
                Nothing lives at this URL. Check the link, or head back to pick
                a worksheet.
            </p>

            <div class="pt-2">
                <a
                    href="/"
                    class="inline-flex items-center gap-2 text-primary hover:underline underline-offset-4"
                >
                    ← Back to worksheets
                </a>
            </div>
        </article>
    </div>
</Layout>
